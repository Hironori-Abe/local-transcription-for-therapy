{
  "productName": "Local Transcription for Therapy (Editor)",
  "identifier": "net.gakkousya.lott-editor",
  "app": {
    "windows": [
      {
        "title": "Local Transcription for Therapy (Editor)",
        "width": 1024,
        "height": 820,
        "maximized": true,
        "resizable": true
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "npm.cmd --prefix frontend run build -- --configuration editorProduction"
  },
  "bundle": {
    "targets": [
      "nsis"
    ],
    "resources": [
      "../LICENSE",
      "../NOTICE",
      "../THIRD_PARTY_LICENSES.md",
      "../licenses",
      "../python_sidecar/prompt_templates",
      "resources/proofread/punctuation_rules"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/editor-hooks.nsh",
        "languages": [
          "Japanese"
        ],
        "displayLanguageSelector": false
      }
    }
  }
}

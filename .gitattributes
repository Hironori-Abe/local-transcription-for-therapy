# Windows batch files must use CRLF line endings
*.bat text eol=crlf

# Shell scripts use LF
*.sh text eol=lf
*.py text eol=lf

# Web/config files use LF
*.ts text eol=lf
*.html text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.txt text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.png binary
*.ico binary
*.gif binary
*.jpg binary
*.jpeg binary
*.zip binary
*.gz binary
*.gguf binary
